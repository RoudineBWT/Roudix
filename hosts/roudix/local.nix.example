# ── local.nix ───────────────────────────────────────────────────────────────
# Personal overrides — this file is gitignored and never overwritten by git pull.
# Copy this file: cp hosts/roudix/local.nix.example hosts/roudix/local.nix
# Then edit to match your hardware and preferences.
# Use lib.mkForce for options that conflict with configuration.nix defaults.
# ────────────────────────────────────────────────────────────────────────────
{ lib, pkgs, ... }:
{
  # ── Desktop ───────────────────────────────────────────────────────────────
  roudix.desktop.type = "niri";               # "niri", "gnome", "kde" or "hyprland"

  # ── Desktop shell ─────────────────────────────────────────────────────────
  # Only used when roudix.desktop.type = "niri" or "hyprland"
  # Controls which shell/bar stack is enabled for the chosen compositor.
  #   "noctalia"  — Noctalia shell   (github:noctalia-dev/noctalia-shell)
  #   "dms"       — DankMaterialShell (github:AvengeMedia/DankMaterialShell)
  #   "caelestia" — Caelestia shell  (github:caelestia-dots/shell)
  roudix.desktop.shell = "noctalia";

  # ── Browser ───────────────────────────────────────────────────────────────
  roudix.browsers = ["helium"];               # "brave", "helium", "vivaldi", "firefox", "librewolf", "chromium" or []
  roudix.zen.enable           = false;        # install Zen Browser (from zen-browser flake input)

  # ── Hardware ──────────────────────────────────────────────────────────────
  hardware.myGpu    = "amd";                  # "amd", "nvidia" or "intel"
  hardware.nvidiaLaptop = false;              # enable this only for Laptops with nvidia Dgpu
  hardware.myCpu    = "intel";               # "intel" or "amd"
  hardware.myKernel = "cachyos-lts-lto-v3"; # see README for all variants

  # ── Optional modules ──────────────────────────────────────────────────────
  roudix.gaming.enable        = true;         # disable to skip Steam, Wine, etc.
  roudix.flatpak.enable       = false;        # enable Flatpak support
  roudix.virtualization.enable = false;       # enable libvirt / virt-manager
  roudix.vmGuest.enable       = false;        # enable only inside a VM
  roudix.autoupdate.enable    = true;         # automatic NixOS updates
  roudix.autoupdate.interval  = "1h";         # check interval (e.g. 1h, 6h, 24h)

  # ── Misc ──────────────────────────────────────────────────────────────────
  roudix.hosts.gtaFix.enable  = false;      # fix GTA Online to play with your friends but they need to block battleye telemetry in /etc/hosts and if they are on windows in C:\Windows\System32\drivers\etc\hosts
  # roudix.autoupdate.branch   = "main";

  # ── Locale / Timezone ─────────────────────────────────────────────────────
  time.timeZone                        = "Europe/Brussels";
  environment.sessionVariables.TZ      = "Europe/Brussels";
  i18n.defaultLocale                   = "en_US.UTF-8";
  console.keyMap                       = "us-accentos";

  # ── Shell ─────────────────────────────────────────────────────────────────
  roudix.shell                         = "fish";        # "fish" or "bash"

  # ── GNOME extensions ──────────────────────────────────────────────────────
  # Only used when roudix.desktop.type = "gnome"
  #
  # Add extensions on top of the defaults — pass the nixpkgs package:
  # roudix.gnome.extraExtensions = with pkgs.gnomeExtensions; [
  #   pop-shell   # <-- the package name from pkgs.gnomeExtensions.*
  # ];
  #
  # Disable a default extension — pass its UUID (the string identifier):
  # roudix.gnome.disabledExtensions = [
  #   "arcmenu@arcmenu.com"   # <-- UUID, not the package name
  # ];
  #
  # You can combine both — e.g. swap ArcMenu for another launcher:
  # roudix.gnome.extraExtensions = with pkgs.gnomeExtensions; [ pop-shell ];
  # roudix.gnome.disabledExtensions = [ "arcmenu@arcmenu.com" ];

  # ── KDE Login Screen wallpaper ────────────────────────────────────────────
  # Only used when roudix.desktop.type = "kde"
  #
  # The Plasma Login Manager copies the wallpaper into /var/lib/plasmalogin/wallpapers/
  # and references it via /etc/plasmalogin.conf.
  # Both the conf and the copy must point to the same wallpaper name.
  #
  # To use a custom wallpaper on the login screen:
  #
  # 1. Override the conf to point to your wallpaper folder name:
  # environment.etc."plasmalogin.conf".text = lib.mkForce ''
  #   [Greeter][Wallpaper][org.kde.image][General]
  #   Image=file:///var/lib/plasmalogin/wallpapers/MyWallpaper
  # '';
  #
  # 2. Override the activation script to copy your wallpaper files:
  # system.activationScripts.plasmaLoginWallpaper = lib.mkForce {
  #   text = ''
  #     install -d -o plasmalogin -g plasmalogin /var/lib/plasmalogin/wallpapers/MyWallpaper/contents/images
  #     cp /path/to/your/wallpaper.png /var/lib/plasmalogin/wallpapers/MyWallpaper/contents/images/wallpaper.png
  #     cp /path/to/your/metadata.json /var/lib/plasmalogin/wallpapers/MyWallpaper/metadata.json
  #     chown -R plasmalogin:plasmalogin /var/lib/plasmalogin/wallpapers/
  #   '';
  # };

  # ── Disk (replace with your own UUID) ─────────────────────────────────────
  # Run: lsblk -f
  # fileSystems."/mnt/gaming" = lib.mkForce {
  #   device = "/dev/disk/by-uuid/YOUR-UUID-HERE";
  #   fsType = "btrfs";
  #   options = [ "defaults" "nofail" ];
  # };
}
