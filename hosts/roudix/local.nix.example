# ── local.nix ───────────────────────────────────────────────────────────────
# Personal overrides — this file is gitignored and never overwritten by git pull.
# Copy this file: cp hosts/roudix/local.nix.example hosts/roudix/local.nix
# Then edit to match your hardware and preferences.
# Use lib.mkForce for options that conflict with configuration.nix defaults.
# ────────────────────────────────────────────────────────────────────────────
{ lib, ... }:
{
  # ── Desktop ───────────────────────────────────────────────────────────────
  roudix.desktop.type = "niri";               # "niri", "gnome" or "kde"

  # ── Browser ───────────────────────────────────────────────────────────────
  roudix.chromium = "helium";                 # "brave", "helium" or "vivaldi"

  # ── Hardware ──────────────────────────────────────────────────────────────
  hardware.myGpu    = "amd";                  # "amd", "nvidia" or "intel"
  hardware.myCpu    = "intel";                # "intel" or "amd"
  hardware.myKernel = "cachyos-lts-lto-v3";  # see README for all variants

  # ── Disk (replace with your own UUID) ─────────────────────────────────────
  # Run: lsblk -f
  # fileSystems."/mnt/gaming" = lib.mkForce {
  #   device = "/dev/disk/by-uuid/YOUR-UUID-HERE";
  #   fsType = "btrfs";
  #   options = [ "defaults" "nofail" ];
  # };

  # ── Optional modules ──────────────────────────────────────────────────────
  # roudix.virtualization.enable = true;
  # roudix.hosts.gtaFix.enable   = false;
}
