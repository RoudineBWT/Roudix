<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE policyconfig PUBLIC
  "-//freedesktop//DTD PolicyKit Policy Configuration 1.0//EN"
  "http://www.freedesktop.org/standards/PolicyKit/1/policyconfig.dtd">

<!--
  Install to: /usr/share/polkit-1/actions/io.roudix.switcher.policy
  (or via NixOS: security.polkit.extraConfig or environment.etc."polkit-1/actions/...")
-->

<policyconfig>

  <vendor>Roudix</vendor>
  <vendor_url>https://roudix.io</vendor_url>

  <action id="io.roudix.switcher.rebuild">
    <description>Switch the Roudix desktop environment and rebuild NixOS</description>
    <message>Authentication is required to switch the desktop environment and rebuild the system configuration.</message>

    <defaults>
      <!-- Active console session: ask for password -->
      <allow_active>auth_self_keep</allow_active>
      <!-- Inactive/remote session: deny -->
      <allow_inactive>no</allow_inactive>
      <!-- Not authenticated at all: deny -->
      <allow_any>no</allow_any>
    </defaults>
  </action>

</policyconfig>
